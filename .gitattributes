# ─── Default behavior ─────────────────────────────────────────────────────────
* text=auto eol=lf

# ─── Source code ──────────────────────────────────────────────────────────────
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.rst   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.env   text eol=lf
*.sql   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.tf    text eol=lf

# ─── Scripts ──────────────────────────────────────────────────────────────────
Makefile     text eol=lf
Dockerfile   text eol=lf

# ─── Binary files ─────────────────────────────────────────────────────────────
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
*.gz    binary
*.tar   binary

# ─── Diff drivers ─────────────────────────────────────────────────────────────
*.py linguist-language=Python
*.ts linguist-language=TypeScript
