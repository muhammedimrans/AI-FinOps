{
  "name": "@costorah/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for COSTORAH — AI usage/cost telemetry",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "costorah",
    "ai",
    "llm",
    "observability",
    "finops",
    "telemetry"
  ],
  "homepage": "https://costorah.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammedimrans/ai-finops",
    "directory": "sdk/javascript"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1079.0",
    "@google/genai": "^2.10.0",
    "@mistralai/mistralai": "^2.4.0",
    "@types/express": "^4.17.25",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cohere-ai": "^8.0.0",
    "eslint": "^8.57.0",
    "express": "^4.22.2",
    "openai": "^6.45.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
