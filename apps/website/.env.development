# Development defaults — committed, no secrets.
# Override locally with .env.development.local (gitignored).

VITE_API_BASE_URL=http://localhost:8000

# Where a successful register/login redirects the browser (ADR-006:
# the two apps are separate origins in production — app.costorah.com —
# but share localhost in development, so this just points at the
# dashboard's own dev server).
VITE_DASHBOARD_URL=http://localhost:5173
