# ─────────────────────────────────────────────────────────────────────────────
# AI FinOps — Environment Variable Template
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-use-a-random-256-bit-value
APP_LOG_LEVEL=INFO

# ─── Authentication (JWT) ─────────────────────────────────────────────────────
# REQUIRED in production: generate with `openssl rand -hex 32`.
# Access tokens are signed with this secret — never reuse APP_SECRET_KEY.
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Backend API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aifinops
POSTGRES_USER=aifinops
POSTGRES_PASSWORD=aifinops_dev_password
DATABASE_URL=postgresql+asyncpg://aifinops:aifinops_dev_password@localhost:5432/aifinops

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=aifinops
CLICKHOUSE_USER=aifinops
CLICKHOUSE_PASSWORD=aifinops_dev_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aifinops-api
METRICS_PORT=9090

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
