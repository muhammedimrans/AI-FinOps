{
  "name": "@costorah/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for COSTORAH — AI usage/cost telemetry",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./lambda": {
      "types": "./dist/lambda.d.ts",
      "import": "./dist/lambda.js",
      "require": "./dist/lambda.cjs"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js",
      "require": "./dist/cloudflare.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "import": "./dist/nest/index.js",
      "require": "./dist/nest/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.0.0",
    "@langchain/core": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "keywords": [
    "costorah",
    "ai",
    "llm",
    "observability",
    "finops",
    "telemetry"
  ],
  "homepage": "https://costorah.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammedimrans/ai-finops",
    "directory": "sdk/javascript"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^2.0.110",
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1079.0",
    "@google/genai": "^2.10.0",
    "@langchain/core": "^0.3.80",
    "@langchain/openai": "^0.3.17",
    "@mistralai/mistralai": "^2.4.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^4.17.25",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "ai": "^5.0.210",
    "cohere-ai": "^8.0.0",
    "eslint": "^8.57.0",
    "express": "^4.22.2",
    "openai": "^6.45.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^4.4.3"
  }
}
