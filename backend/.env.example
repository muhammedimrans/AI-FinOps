# ─────────────────────────────────────────────────────────────────────────────
# AI FinOps — Backend Environment Template
# Copy to backend/.env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Database — full connection URL (takes priority over individual POSTGRES_* vars).
# Local Docker:  postgresql+asyncpg://aifinops:password@localhost:5432/aifinops
# Neon:          postgresql+asyncpg://<user>:<pass>@<host>.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Application
APP_ENV=development
APP_NAME=AI FinOps
LOG_LEVEL=INFO

# Secret keys (minimum 32 characters in all environments)
APP_SECRET_KEY=
JWT_SECRET=
