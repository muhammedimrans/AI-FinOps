{
  "name": "@costorah/shared-ui",
  "version": "0.1.0",
  "description": "Shared design-system primitives (class-name utility, design tokens) for apps/website and apps/dashboard",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
