{
  "name": "@costorah/api-contracts",
  "version": "0.1.0",
  "description": "API request/response contracts for the AI FinOps platform",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@costorah/shared-types": "workspace:*",
    "@costorah/error-codes": "workspace:*",
    "@costorah/event-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
