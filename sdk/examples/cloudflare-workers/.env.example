# Cloudflare Workers reads config from wrangler secrets/vars, not a
# .env file — this file documents which values to set, for reference:
#
#   wrangler secret put COSTORAH_API_KEY
#   wrangler secret put OPENAI_API_KEY
COSTORAH_API_KEY=costorah_live_xxxxxxxxx
OPENAI_API_KEY=sk-your-openai-key-here
